--- Get all products where brand is 'Apple' AND price is greater than 80000.
select * from products where brand='apple' and price>80000;

-- Get all products where category is 'Accessories' OR price is less than 5000.
select * from products where category='accessories' or price<5000;


-- Get all products where category is 'Electronics' AND stock is more than 10.
select * from products where category='electronics' and stock<10;


-- Get all products where brand is 'Apple' OR brand is 'Samsung' AND price is less than 90000.
select * from products where (brand='apple' or brand='samsung') and price <90000; 


-- Get all products where category is NOT 'Accessories' OR rating is less than 4.5.
select * from products where category!='accessories' or rating<4.5;

-- Get all products where price is between 10000 AND 70000 AND brand is NOT 'Apple'.
select * from products where price between 10000 and 70000 and (brand!='apple');
